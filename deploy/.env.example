# ===== BACKEND (Render dashboard) =====
# Set these in Render → Web Service → Environment
VOIDAI_API_KEY=your_voidai_api_key_here
VOIDAI_BASE_URL=https://api.voidai.app/v1
VOIDAI_MODEL=gpt-5-mini

# ===== FRONTEND (Appwrite Site dashboard, also frontend/.env for local dev) =====
# All VITE_-prefixed vars are exposed to the client. Never put secrets here.
VITE_APPWRITE_PROJECT_ID=your_project_id
VITE_APPWRITE_DB_ID=your_db_id
VITE_RENDER_API_URL=https://your-backend.onrender.com
